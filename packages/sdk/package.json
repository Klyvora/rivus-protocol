{
  "name": "@rivus/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Rivus payment streaming protocol on Soroban",
  "author": "mubking <https://github.com/mubking>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Klyvora/rivus-protocol.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": ["stellar", "soroban", "streaming", "payments", "sdk", "rivus"],
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  }
}